{
  "name": "@flyer-watch/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./init-db": {
      "types": "./dist/init-db.d.ts",
      "default": "./dist/init-db.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "find dist -name '*.test.js' -print0 | xargs -0 node --test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "nodemailer": "7.0.11",
    "openid-client": "6.8.1",
    "pg": "8.16.3",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@types/pg": "8.15.6"
  }
}
